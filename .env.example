# Telegram (optional) — bot must be admin of the channel to post
# Uncomment and set your real values; do not use the placeholder token below.
# TELEGRAM_ENABLED=1
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHANNEL_ID=@your_channel
# or numeric channel id: -1001234567890

# TorZlink paths (optional; legacy TORLINK_* still supported)
# TORZLINK_STATE_DIR=/data
# TORZLINK_DOWNLOAD_DIR=/downloads
# TORZLINK_DISABLE_NAT=1
# TORZLINK_SKIP_UPDATE=1
